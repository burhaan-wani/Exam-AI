MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=exam_ai
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key
# Text/chat model for syllabus extraction, question bank generation, paper generation, and evaluation.
OPENROUTER_TEXT_MODEL=openai/gpt-oss-120b:free
# Vision-capable model for scanned/image template parsing.
OPENROUTER_VISION_MODEL=google/gemma-3-4b-it:free
# Legacy fallback setting; prefer OPENROUTER_TEXT_MODEL and OPENROUTER_VISION_MODEL.
OPENROUTER_MODEL=
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5173
