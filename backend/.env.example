MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=exam_ai
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Must be a CHAT model (e.g. openai/gpt-3.5-turbo, meta-llama/llama-3-8b-instruct:free). Do NOT use an embedding model.
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Embedding model for RAG (must support embeddings endpoint)
OPENROUTER_EMBEDDING_MODEL=text-embedding-3-small
# Vector store backend: chroma | faiss
VECTOR_STORE_BACKEND=chroma
# Chroma persistence directory (relative to backend/)
CHROMA_PERSIST_DIR=./data/chroma
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5173
